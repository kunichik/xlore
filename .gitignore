# Obsidian: ignore volatile/machine-local state, keep shareable config if you commit it.
.obsidian/workspace*
.obsidian/cache
.obsidian/plugins/*/data.json

# collect-raw.sh staging area (review before you ever commit raw/)
raw/**/*.partial

